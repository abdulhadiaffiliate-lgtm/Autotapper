<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="AutoTapper"
            android:textColor="@color/text_primary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp"
            android:text="Configure your tap automation"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <!-- Status Card -->
        <LinearLayout
            android:id="@+id/cardStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="18dp"
            android:layout_marginBottom="16dp">

            <View
                android:id="@+id/statusDot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/bg_crosshair"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/status_ready"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Permissions Card -->
        <LinearLayout
            android:id="@+id/cardPermissions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="18dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Setup"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnEnableService"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_btn_primary"
                android:text="@string/btn_enable_service"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnEnableOverlay"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_btn_primary"
                android:text="@string/btn_enable_overlay"
                android:textColor="@color/white"
                android:textAllCaps="false" />
        </LinearLayout>

        <!-- Settings Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="18dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_settings"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="14dp" />

            <!-- Interval -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_interval"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderInterval"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:valueFrom="20"
                    android:valueTo="2000"
                    android:value="100"
                    app:thumbColor="@color/accent"
                    app:trackColorActive="@color/accent"
                    app:trackColorInactive="@color/surface_light" />

                <TextView
                    android:id="@+id/tvIntervalValue"
                    android:layout_width="64dp"
                    android:layout_height="wrap_content"
                    android:text="100ms"
                    android:textColor="@color/accent_light"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="end" />
            </LinearLayout>

            <!-- Jitter -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/label_jitter"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderJitter"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:valueFrom="0"
                    android:valueTo="80"
                    android:value="15"
                    app:thumbColor="@color/accent"
                    app:trackColorActive="@color/accent"
                    app:trackColorInactive="@color/surface_light" />

                <TextView
                    android:id="@+id/tvJitterValue"
                    android:layout_width="64dp"
                    android:layout_height="wrap_content"
                    android:text="15%"
                    android:textColor="@color/accent_light"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="end" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Adds slight randomness to timing and position so taps feel less mechanical"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />

            <!-- Tap count limit -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/label_tap_count"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchInfinite"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_infinite"
                    android:textColor="@color/text_primary"
                    android:checked="true" />

                <EditText
                    android:id="@+id/etTapCount"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_card"
                    android:enabled="false"
                    android:gravity="center"
                    android:hint="100"
                    android:inputType="number"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Tap point card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="18dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap Point"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/tvTapPoint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Not set — defaults to screen center"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnSetPoint"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_card"
                android:text="@string/btn_set_point"
                android:textColor="@color/accent_light"
                android:textAllCaps="false" />
        </LinearLayout>

        <!-- Start/Stop button -->
        <Button
            android:id="@+id/btnStartStop"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_btn_primary"
            android:text="@string/btn_start"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textAllCaps="false" />

    </LinearLayout>
</ScrollView>
